{
  "$schema": "https://biomejs.dev/schemas/2.2.0/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "includes": [
      "**",
      "!.agents",
      "!.agents/**",
      "!docs",
      "!docs/**",
      "!tasks",
      "!tasks/**",
      "!node_modules",
      "!node_modules/**",
      "!dist",
      "!dist/**",
      "!.next",
      "!.next/**",
      "!.turbo",
      "!.turbo/**",
      "!coverage",
      "!coverage/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always",
      "trailingCommas": "all"
    }
  }
}
