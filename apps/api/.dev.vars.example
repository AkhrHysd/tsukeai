# Cloudflare Workers secrets for local development (wrangler dev).
# Copy this file to .dev.vars and fill in the values.

# --- Required ---

# HMAC key for signing session cookies. Any random string works locally.
SESSION_SECRET=local-dev-secret-change-me

# --- LLM (required when running real transforms; omit or leave blank key for smoke-only) ---

# API key for the OpenAI-compatible chat completions endpoint.
LLM_API_KEY=

# Absolute https URL for the chat completions API (no defaults in application code).
LLM_BASE_URL=

# Model id for that endpoint (no defaults in application code).
LLM_MODEL=

# --- Optional (LLM tuning) ---

# LLM_TIMEOUT_MS=8000
# LLM_MAX_INPUT_CHARS=1000
# LLM_MAX_OUTPUT_TOKENS=96
# LLM_MAX_RETRIES=1

# Set to "1" to bypass LLM and publish fixed tanka text (for testing).
WRITE_SMOKE_FIXED_PUBLIC_TEXT=1
