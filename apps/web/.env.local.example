# Next.js environment variables for local development.
# Copy this file to .env.local.

# API base URL. Defaults to http://localhost:8787 when not set.
# API_BASE_URL=http://localhost:8787
#
# For local passkey auth, set apps/api/.dev.vars SESSION_COOKIE_NAME=tsukeai_session
# and PUBLIC_WEB_ORIGIN=http://localhost:3000. The production default
# __Host-tsukeai_session requires HTTPS.

# Set to "1" to bypass LLM and publish fixed tanka text (for testing).
WRITE_SMOKE_FIXED_PUBLIC_TEXT=1

# To use mock API data without a running backend:
#   1. Run: pnpm mock       (starts mock-api-server.mjs on port 3001)
#   2. Set: API_BASE_URL=http://localhost:3001
# API_BASE_URL=http://localhost:3001
